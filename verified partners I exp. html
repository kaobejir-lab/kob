// Count stores per brand
function brandStoreCount(brand) {
  return STORES.filter(s => [...s.w, ...s.b].includes(brand)).length;
}

const getFuzzySuggestion = (query) => {
  if(!query) return null;
  const t = query.toLowerCase().trim();
  const map = [
    { valid: "Rolex", mistakes: ["โลเล็ก","โลเลก","โรเล็ก","คอเหล็ก","lolex","rolexs","โรเรก","โรเล็ค"] },
    { valid: "Patek Philippe", mistakes: ["ปาเตก","ปาเต๊ะ","พาเทก","พาเท็ก","ปาเต็ก","patek","patex"] },
    { valid: "Hermès", mistakes: ["แอร์เมส","แอเมส","เฮอเมส","เฮอร์มีส","hermes"] },
    { valid: "Chanel", mistakes: ["ชาแนล","แชแนล","chanell","ชแนล"] },
    { valid: "Louis Vuitton", mistakes: ["หลุย","หลุยส์","วิตตอง","louis","lv"] },
    { valid: "Audemars Piguet", mistakes: ["เอดพี่","เอพี","ap","audemar"] },
    { valid: "Cartier", mistakes: ["คาเทีย","คาร์เทีย","cartie"] }
  ];
  for(let i=0;i<map.length;i++) {
    if(map[i].mistakes.some(m => t.includes(m) || m.includes(t))) return map[i].valid;
  }
  return null;
};

