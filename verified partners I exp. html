function App() {
  const [tab, setTab] = useState("all");
  const [view, setView] = useState("grid");
  const [q, setQ] = useState("");
  const [cond, setCond] = useState("all");
  const [selBr, setSelBr] = useState([]);
  const [sheet, setSheet] = useState(false);
  const [sheetQ, setSheetQ] = useState("");
  const [det, setDet] = useState(null);
  const [selBranchId, setSelBranchId] = useState(null);
  const [mR, setMR] = useState(null);
  const [brQ, setBrQ] = useState("");
  const [toast, setToast] = useState(null);

  const [srcFocus, setSrcFocus] = useState(false);

  const [favs, setFavs] = useState(() => JSON.parse(localStorage.getItem('bm_favs') || '[]'));
  useEffect(() => localStorage.setItem('bm_favs', JSON.stringify(favs)), [favs]);

  const [userPos, setUserPos] = useState(null);
  const [nearbyOn, setNearbyOn] = useState(false);
  const [locating, setLocating] = useState(false);

  const [voiceOpen, setVoiceOpen] = useState(false);
  const [voiceText, setVoiceText] = useState("");
  const [voiceListening, setVoiceListening] = useState(false);
  const [voiceError, setVoiceError] = useState(null);
  const recogRef = useRef(null);
  const voiceTargetRef = useRef("search");
  const timerRef = useRef(null);

  const showToast = useCallback((msg) => { setToast(msg); setTimeout(() => setToast(null), 2600); }, []);

  const toggleFav = useCallback((id, ev) => {
    ev.stopPropagation(); triggerHaptic();
    setFavs(p => {
       const n = p.includes(id) ? p.filter(x=>x!==id) : [...p, id];
       if(!p.includes(id)) showToast("บันทึกร้านโปรดแล้ว 🤍");
       return n;
    });
  }, [showToast]);

  const handleNearby = useCallback(() => {
    triggerHaptic();
    if (nearbyOn) {
      setNearbyOn(false); setUserPos(null); showToast("ปิดการค้นหาใกล้ฉันแล้ว"); return;
    }
    if (!navigator.geolocation) { showToast("เบราว์เซอร์ไม่รองรับ GPS"); return; }
    setLocating(true); setCond('all');
    navigator.geolocation.getCurrentPosition(
      (pos) => {
        setUserPos({ lat: pos.coords.latitude, lng: pos.coords.longitude });
        setNearbyOn(true); setLocating(false); showToast("✓ เรียงร้านค้าตามระยะทางแล้ว");
      },
      (err) => {
        setLocating(false);
        if (err.code === 1) showToast("กรุณาอนุญาตการเข้าถึง Location");
        else showToast("ไม่สามารถระบุตำแหน่งได้");
      },
      { timeout: 8000, maximumAge: 60000 }
    );
  }, [nearbyOn, showToast]);

  const startListening = useCallback(() => {
    const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (!SR) { setVoiceError("เบราว์เซอร์นี้ไม่รองรับการค้นหาด้วยเสียง"); return; }
    setVoiceError(null); setVoiceText("");
    try {
      const r = new SR(); r.lang = "th-TH"; r.continuous = false; r.interimResults = true;
      r.onstart = () => { triggerHaptic(); setVoiceListening(true); };
      r.onresult = (ev) => {
        let text = ""; for (let i = 0; i < ev.results.length; i++) text += ev.results[i][0].transcript;
        setVoiceText(text); clearTimeout(timerRef.current);
        if (ev.results[0].isFinal || text.trim() !== "") {
          timerRef.current = setTimeout(() => {
            const finalTxt = text.trim();
            if (voiceTargetRef.current === "sheet") setSheetQ(finalTxt);
            else { setQ(finalTxt); setMR(null); }
            closeVoice(); showToast(`ค้นหา: "${finalTxt}"`); triggerHaptic();
          }, 1500);
        }
      };
      r.onerror = (ev) => {
        setVoiceListening(false);
        if (ev.error === 'not-allowed') setVoiceError("กรุณาอนุญาตให้ใช้งานไมโครโฟน");
        else if (ev.error === 'no-speech') setVoiceError("ไม่ได้ยินเสียง กรุณาลองพูดอีกครั้ง");
        else if (ev.error === 'network') setVoiceError("การเชื่อมต่อผิดพลาด");
        else setVoiceError("เกิดข้อผิดพลาด กรุณาลองใหม่");
      };
      r.onend = () => setVoiceListening(false);
      recogRef.current = r; r.start();
    } catch (err) { setVoiceError("ไม่สามารถเริ่มการรับเสียงได้"); setVoiceListening(false); }
  }, []);

  const openVoice = useCallback((target = "search") => { triggerHaptic(); voiceTargetRef.current = target; setVoiceText(""); setVoiceError(null); setVoiceOpen(true); setTimeout(() => startListening(), 300); }, [startListening]);
  const closeVoice = useCallback(() => { triggerHaptic(); if (recogRef.current) { try { recogRef.current.stop(); } catch(e){} } clearTimeout(timerRef.current); setVoiceOpen(false); setVoiceListening(false); setVoiceText(""); setVoiceError(null); }, []);
  const submitVoice = useCallback(() => { if (!voiceText.trim()) return; const finalTxt = voiceText.trim(); if (voiceTargetRef.current === "sheet") setSheetQ(finalTxt); else { setQ(finalTxt); setMR(null); } closeVoice(); showToast(`ค้นหา: "${finalTxt}"`); }, [voiceText, closeVoice, showToast]);
  const openMap = (address, ev) => { triggerHaptic(); if (ev) ev.stopPropagation(); window.open(`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address)}`, '_blank'); };
  const applyLoan = (store, ev) => { triggerHaptic(); if (ev) ev.stopPropagation(); showToast(`✓ กำลังเริ่มสมัครสินเชื่อที่ ${store.n}`); };

  const currentMatchedModel = useMemo(() => detectModel(q), [q]);

  // SMART SUGGESTIONS GENERATOR 
  const suggestions = useMemo(() => {
    if (!q.trim()) return [];
    const query = q.toLowerCase();
    let res = [];
    
    ALL_BR.forEach(b => { if(b.toLowerCase().includes(query)) res.push({ text: b, matchText: b, type: 'แบรนด์', ic: CertIc }); });
    KNOWN_MODELS.forEach(m => { if(m.id.includes(query) || m.n.toLowerCase().includes(query) || m.desc.toLowerCase().includes(query)) res.push({ text: m.n, matchText: m.n, type: 'รุ่นนาฬิกา', ic: WatchIc }); });
    STORES.forEach(s => { if(s.n.toLowerCase().includes(query) || s.a.toLowerCase().includes(query)) res.push({ text: s.n, matchText: s.n, type: 'ร้านค้า', ic: FolderIc }); });
    
    // Fuzzy matching integration into dropdown
    const fuzzy = getFuzzySuggestion(q);
    if (fuzzy && fuzzy.toLowerCase() !== query.trim()) {
       const isBrand = ALL_BR.includes(fuzzy);
       if (!res.some(r => r.matchText === fuzzy)) {
          // Add smart suggestion at the very top
          res.unshift({ matchText: fuzzy, text: `คุณหมายถึง "${fuzzy}" ใช่ไหม?`, type: 'แนะนำ', ic: isBrand ? CertIc : FolderIc });
       }
    }
    return res.slice(0, 6);
  }, [q]);

  const parsedQ = useMemo(() => {
    let text = q.toLowerCase();
    let isW = text.includes('นาฬิกา') || text.includes('watch');
    let isB = text.includes('กระเป๋า') || text.includes('bag');
    let isPre = text.includes('มือสอง') || text.includes('มือ 2') || text.includes('used');
    let isNew = text.includes('มือหนึ่ง') || text.includes('มือ 1') || text.includes('new');
    let clean = text.replace(/นาฬิกา|กระเป๋า|มือสอง|มือ\s*2|มือหนึ่ง|มือ\s*1|watch|bag|used|new/g, '').trim();
    return { clean, isW, isB, isPre, isNew };
  }, [q]);

  const selectSuggestion = (txt) => { triggerHaptic(); setQ(txt); setSrcFocus(false); setMR(null); };

  const handleShare = () => {
    triggerHaptic();
    const url = window.location.href;
    const text = `แวะดูร้าน ${detStore.n} แหล่งรวมแบรนด์เนมคัดเกรดบน Brandname Money`;
    if (navigator.share) {
      navigator.share({ title: detStore.n, text: text, url: url }).catch(()=>{});
    } else {
      const el = document.createElement('textarea');
      el.value = `${text} ${url}`; el.setAttribute('readonly', ''); el.style.position = 'absolute'; el.style.left = '-9999px'; document.body.appendChild(el); el.select(); document.execCommand('copy'); document.body.removeChild(el);
      showToast("คัดลอกลิงก์ร้านค้าแล้ว");
    }
  };

  const getList = useCallback((t) => {
    let list = STORES.filter((s) => {
      if (mR && !mR.stores.includes(s.id)) return false;
      if (t === "watch" && s.w.length === 0) return false;
      if (t === "bag" && s.b.length === 0) return false;
      if (cond === "new" && !s.c.includes("new")) return false;
      if (cond === "pre" && !s.c.includes("pre")) return false;
      if (cond === "fav" && !favs.includes(s.id)) return false; 
      
      const br = t === "watch" ? s.w : t === "bag" ? s.b : [...s.w, ...s.b];
      
      if (!mR) {
        if (selBr.length > 0 && !selBr.some((x) => br.includes(x))) return false;
        if (currentMatchedModel) {
          return s.m && s.m.includes(currentMatchedModel.id);
        } else if (q) {
          const { clean, isW, isB, isPre, isNew } = parsedQ;
          
          // SMART FILTER FALLBACK: if user types "ทง" we filter against "thong patek" directly!
          const fuzzy = getFuzzySuggestion(q);
          const activeQuery = fuzzy ? fuzzy.toLowerCase() : clean;
          
          if (isW && s.w.length === 0) return false;
          if (isB && s.b.length === 0) return false;
          if (isPre && !s.c.includes("pre")) return false;
          if (isNew && !s.c.includes("new")) return false;

          if (activeQuery) {
             return s.n.toLowerCase().includes(activeQuery) || 
                    s.a.toLowerCase().includes(activeQuery) || 
                    br.some((b) => b.toLowerCase().includes(activeQuery));
          }
        }
      }
      return true;
    });
    if (nearbyOn && userPos) {
      list = [...list].sort((a, b) => {
        const da = a.lat ? calcDist(userPos.lat, userPos.lng, a.lat, a.lng) : 9999;
        const db = b.lat ? calcDist(userPos.lat, userPos.lng, b.lat, b.lng) : 9999;
        return da - db;
      });
    }
    return list;
  }, [cond, selBr, q, parsedQ, mR, currentMatchedModel, nearbyOn, userPos, favs]);

  const allS = useMemo(() => getList("all"), [getList]);
  const ws = useMemo(() => getList("watch"), [getList]);
  const bs = useMemo(() => getList("bag"), [getList]);
  const dispCount = tab === "watch" ? ws.length : tab === "bag" ? bs.length : allS.length;

  // Render fuzzy match banner if we are auto-filtering via activeQuery alias
  const activeFuzzy = useMemo(() => getFuzzySuggestion(q), [q]);
  const showFuzzyBanner = activeFuzzy && q.toLowerCase().trim() !== activeFuzzy.toLowerCase() && dispCount > 0;
  const fuzzyBanner = showFuzzyBanner ? e('div', { style: { background: '#FFFBF5', border: '1px solid #EFE4D8', borderRadius: 12, padding: '10px 16px', marginBottom: 20, display: 'flex', alignItems: 'center', gap: 8, color: '#5A4A3D', fontSize: 13, boxShadow: '0 4px 12px rgba(162,123,82,0.08)' } },
    e(SearchIc, {s:16}), `แสดงผลการค้นหาสำหรับ "${activeFuzzy}"`
  ) : null;

  const detStore = det ? det.store : null;
  const activeBranch = (detStore && selBranchId) ? detStore.branches.find(b => b.id === selBranchId) : null;
  const activeSoc = activeBranch ? activeBranch.soc : (detStore ? detStore.soc : {});
  const dSocKeys = ["tel","line","fb","ig","x","tiktok"].filter(k => activeSoc && activeSoc[k]);
  const otherBranches = detStore && detStore.branches ? detStore.branches : [];

  useEffect(() => { setSelBranchId(null); setBrQ(""); }, [det]);

  const suggestedBrand = (dispCount === 0 && q.trim() !== "" && !currentMatchedModel) ? getFuzzySuggestion(q) : null;
  const hasFilter = cond !== "all" || selBr.length > 0 || q || nearbyOn;

  return e('div', { className: 'layout' },

    // HERO
    e('div', { className: 'hero-wrap' },
      e('div', { className: 'hero-txt' },
        e('div', { className: 'h-badge' }, e(CertIc, {s:15}), "BM's Partners"),
        e('h1', { className: 'h-title' }, "ร้านค้าพาร์ตเนอร์"),
        e('div', { className: 'h-sub' }, "เลือกชมร้านค้าที่ผ่านการตรวจสอบ พร้อมบริการแบ่งชำระได้อย่างมั่นใจ")
      ),
