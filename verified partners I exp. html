// FUZZY MAP UPDATE
const getFuzzySuggestion = (query) => {
  if(!query || query.trim().length < 2) return null;
  const t = query.toLowerCase().trim();
  
  // Mapping dictionary (Support Thai typing mistakes / nicknames)
  const map = [
    { valid: "THONG PATEK", mistakes: ["ทง","ทอง","ทองปาเต๊ะ","thong"] },
    { valid: "Luxe Gallery Bangkok", mistakes: ["ลักซ","ลักซ์","lux","luxe"] },
    { valid: "Pendulum", mistakes: ["แพนดู","เพนดู","pendulum","เพนดูลัม"] },
    { valid: "Siam Swiss", mistakes: ["สยามสวิส"] },
    { valid: "Rolex", mistakes: ["โลเล็ก","โลเลก","โรเล็ก","คอเหล็ก","lolex","rolexs","โรเรก","โรเล็ค","โรเล็กซ์","โรเลกซ์"] },
    { valid: "Patek Philippe", mistakes: ["ปาเตก","ปาเต๊ะ","พาเทก","พาเท็ก","ปาเต็ก","patek","patex","ปาเตค"] },
    { valid: "Hermès", mistakes: ["แอร์เมส","แอเมส","เฮอเมส","เฮอร์มีส","hermes","แอมเมส"] },
    { valid: "Chanel", mistakes: ["ชาแนล","แชแนล","chanell","ชแนล"] },
    { valid: "Louis Vuitton", mistakes: ["หลุย","หลุยส์","วิตตอง","louis","lv","หลุยส"] },
    { valid: "Audemars Piguet", mistakes: ["เอดพี่","เอพี","ap","audemar","โอเดอมาร์"] },
    { valid: "Cartier", mistakes: ["คาเทีย","คาร์เทีย","cartie","คาร์เทียร์"] }
  ];
  
  for(let i=0;i<map.length;i++) { 
     if(map[i].mistakes.some(m => t === m || (t.length >= 2 && m.includes(t)) || (m.length >= 3 && t.includes(m)))) {
        return map[i].valid;
     }
  }
  
  // Optional: Levenshtein distance fallback for typing errors >= 3 chars
  if (t.length >= 3) {
    let closest = null;
    let minD = 99;
    const checkList = [...ALL_BR, ...STORES.map(s=>s.n)];

    const dist = (a, b) => {
      if(!a.length) return b.length; if(!b.length) return a.length;
      const m = []; for(let i=0;i<=b.length;i++) m[i]=[i]; for(let j=0;j<=a.length;j++) m[0][j]=j;
      for(let i=1;i<=b.length;i++){
        for(let j=1;j<=a.length;j++){
          if(b.charAt(i-1)===a.charAt(j-1)) m[i][j]=m[i-1][j-1];
          else m[i][j]=Math.min(m[i-1][j-1]+1, Math.min(m[i][j-1]+1, m[i-1][j]+1));
        }
      }
      return m[b.length][a.length];
    };

    checkList.forEach(w => {
      const wL = w.toLowerCase();
      if (wL.includes(t) && !closest) { closest = w; minD = 0; return; }
      const wParts = wL.split(' ');
      const tParts = t.split(' ');
      wParts.forEach(wp => {
        tParts.forEach(tp => {
           if (tp.length > 2) {
             const d = dist(wp, tp);
             if (d <= 2 && d < minD) { minD = d; closest = w; }
           }
        });
      });
    });
    return minD <= 2 ? closest : null;
  }
  return null;
};

