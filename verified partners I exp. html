function App() {
  const [tab, setTab] = useState("all");
  const [view, setView] = useState("grid");
  const [q, setQ] = useState("");
  const [cond, setCond] = useState("all");
  const [selBr, setSelBr] = useState([]);
  const [sheet, setSheet] = useState(false);
  const [sheetQ, setSheetQ] = useState("");
  const [det, setDet] = useState(null);
  const [selBranchId, setSelBranchId] = useState(null);
  const [mR, setMR] = useState(null);
  const [brQ, setBrQ] = useState("");
  const [toast, setToast] = useState(null);

  const [voiceOpen, setVoiceOpen] = useState(false);
  const [voiceText, setVoiceText] = useState("");
  const [voiceListening, setVoiceListening] = useState(false);
  const [voiceError, setVoiceError] = useState(null);
  const recogRef = useRef(null);
  const voiceTargetRef = useRef("search");
  const timerRef = useRef(null);

  const showToast = useCallback((msg) => {
    setToast(msg); setTimeout(() => setToast(null), 2600);
  }, []);

  const translateVoice = (text) => {
    let t = text.toLowerCase().trim();
    const map = {
      "ทง": "THONG PATEK","ทอง": "THONG PATEK","ทองปาเต๊ะ": "THONG PATEK",
      "ลักซ": "Luxe Gallery","ลักซ์": "Luxe Gallery","lux": "Luxe Gallery",
      "สยามสวิส": "Siam Swiss","siam swiss": "Siam Swiss",
      "แพนดู": "Pendulum","เพนดู": "Pendulum","pendulum": "Pendulum",
      "พารากอน": "พารากอน","เอ็มควอเทียร์": "เอ็มควอเทียร์","เซ็นทรัล": "เซ็นทรัล",
      "โอเมก้า": "Omega","โอเมกา": "Omega","ฮับลอท": "Hublot","อับลอท": "Hublot"
    };
    for (let key in map) { if (t.includes(key)) return map[key]; }
    const fuzzy = getFuzzySuggestion(t);
    if(fuzzy) return fuzzy;
    return text;
  };

  const startListening = useCallback(() => {
    const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (!SR) { setVoiceError("เบราว์เซอร์นี้ไม่รองรับการค้นหาด้วยเสียง"); return; }
    setVoiceError(null); setVoiceText("");
    try {
      const r = new SR();
      r.lang = "th-TH"; r.continuous = false; r.interimResults = true;
      r.onstart = () => { triggerHaptic(); setVoiceListening(true); };
      r.onresult = (ev) => {
        let text = "";
        for (let i = 0; i < ev.results.length; i++) text += ev.results[i][0].transcript;
        setVoiceText(text);
        clearTimeout(timerRef.current);
        if (ev.results[0].isFinal || text.trim() !== "") {
          timerRef.current = setTimeout(() => {
            const finalTxt = translateVoice(text);
            if (voiceTargetRef.current === "sheet") setSheetQ(finalTxt);
            else { setQ(finalTxt); setMR(null); }
            closeVoice(); showToast(`ค้นหา: "${finalTxt}"`); triggerHaptic();
          }, 1500);
        }
      };
      r.onerror = (ev) => {
        setVoiceListening(false);
        if (ev.error === 'not-allowed') setVoiceError("กรุณาอนุญาตให้ใช้งานไมโครโฟน");
        else if (ev.error === 'no-speech') setVoiceError("ไม่ได้ยินเสียง กรุณาลองพูดอีกครั้ง");
        else if (ev.error === 'network') setVoiceError("การเชื่อมต่อผิดพลาด");
        else setVoiceError("เกิดข้อผิดพลาด กรุณาลองใหม่");
      };
      r.onend = () => setVoiceListening(false);
      recogRef.current = r; r.start();
    } catch (err) {
      setVoiceError("ไม่สามารถเริ่มการรับเสียงได้"); setVoiceListening(false);
    }
  }, []);

  const openVoice = useCallback((target = "search") => {
    triggerHaptic(); voiceTargetRef.current = target;
    setVoiceText(""); setVoiceError(null); setVoiceOpen(true);
    setTimeout(() => startListening(), 300);
  }, [startListening]);

  const closeVoice = useCallback(() => {
    triggerHaptic();
    if (recogRef.current) { try { recogRef.current.stop(); } catch(e){} }
    clearTimeout(timerRef.current);
    setVoiceOpen(false); setVoiceListening(false); setVoiceText(""); setVoiceError(null);
  }, []);

  const submitVoice = useCallback(() => {
    if (!voiceText.trim()) return;
    const finalTxt = translateVoice(voiceText);
    if (voiceTargetRef.current === "sheet") setSheetQ(finalTxt);
    else { setQ(finalTxt); setMR(null); }
    closeVoice(); showToast(`ค้นหา: "${finalTxt}"`);
  }, [voiceText, closeVoice, showToast]);

  const openMap = (address, ev) => {
    triggerHaptic(); if (ev) ev.stopPropagation();
    window.open(`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address)}`, '_blank');
  };

  const applyLoan = (store, ev) => {
    triggerHaptic(); if (ev) ev.stopPropagation();
    showToast(`✓ กำลังเริ่มสมัครสินเชื่อที่ ${store.n}`);
  };

  const getList = useCallback((t) => {
    return STORES.filter((s) => {
      if (mR && !mR.stores.includes(s.id)) return false;
      if (t === "watch" && s.w.length === 0) return false;
      if (t === "bag" && s.b.length === 0) return false;
      if (cond === "new" && !s.c.includes("new")) return false;
      if (cond === "pre" && !s.c.includes("pre")) return false;
      const br = t === "watch" ? s.w : t === "bag" ? s.b : [...s.w, ...s.b];
      if (!mR) {
        if (selBr.length > 0 && !selBr.some((x) => br.includes(x))) return false;
        if (q) {
          const x = q.toLowerCase();
          return s.n.toLowerCase().includes(x) || s.a.toLowerCase().includes(x) || br.some((b) => b.toLowerCase().includes(x));
        }
      }
      return true;
    });
  }, [cond, selBr, q, mR]);

  const ws = useMemo(() => getList("watch"), [getList]);
  const bs = useMemo(() => getList("bag"), [getList]);
  const dispCount = tab === "watch" ? ws.length : tab === "bag" ? bs.length : ws.length + bs.length;

  const detStore = det ? det.store : null;
  const activeBranch = (detStore && selBranchId) ? detStore.branches.find(b => b.id === selBranchId) : null;
  const activeSoc = activeBranch ? activeBranch.soc : (detStore ? detStore.soc : {});
  const dSocKeys = ["tel","line","fb","ig","x","tiktok"].filter(k => activeSoc && activeSoc[k]);
  const otherBranches = detStore && detStore.branches ? detStore.branches : [];

  useEffect(() => { setSelBranchId(null); setBrQ(""); }, [det]);

  const suggestedBrand = (dispCount === 0 && q.trim() !== "") ? getFuzzySuggestion(q) : null;

  return e('div', { className: 'layout' },

    // HERO
    e('div', { className: 'hero-wrap' },
      e('div', { className: 'hero-txt' },
        e('div', { className: 'h-badge' }, e(CertIc, {s:15}), "BM's Partners"),
        e('h1', { className: 'h-title' }, "ร้านค้าพาร์ตเนอร์"),
        e('div', { className: 'h-sub' }, "เลือกชมร้านค้าที่ผ่านการตรวจสอบ พร้อมบริการแบ่งชำระได้อย่างมั่นใจ")
      ),
      e('div', { className: 'hero-stats' },
        e('div', { className: `hs-blk ${tab==='all'?'on':''}`, onClick: () => {triggerHaptic(); setTab('all');} },
          e('div',{className:'hs-ic'}, e(GlobeIc,{s:24})), e('div',{className:'hs-v'},NUM_ALL), e('div',{className:'hs-l'},"ทั้งหมด")),
        e('div', { className: `hs-blk ${tab==='watch'?'on':''}`, onClick: () => {triggerHaptic(); setTab('watch');} },
          e('div',{className:'hs-ic'}, e(WatchIc,{s:24,c:"currentColor"})), e('div',{className:'hs-v'},NUM_WATCH), e('div',{className:'hs-l'},"นาฬิกา")),
        e('div', { className: `hs-blk ${tab==='bag'?'on':''}`, onClick: () => {triggerHaptic(); setTab('bag');} },
          e('div',{className:'hs-ic'}, e(BagIc,{s:24,c:"currentColor"})), e('div',{className:'hs-v'},NUM_BAG), e('div',{className:'hs-l'},"กระเป๋า"))
      )
    ),

    // TOOLBAR
    e('div', { className: 'tbar' },
      e('div', { className: 'tb-tabs' },
        e('button', { className: `t-tab ${tab==='all'?'on':''}`, onClick:()=>{triggerHaptic(); setTab('all');} }, e(GlobeIc,{s:16}), "ทั้งหมด"),
        e('button', { className: `t-tab ${tab==='watch'?'on':''}`, onClick:()=>{triggerHaptic(); setTab('watch');} }, e(WatchIc,{s:16,c:"currentColor"}), "นาฬิกา"),
        e('button', { className: `t-tab ${tab==='bag'?'on':''}`, onClick:()=>{triggerHaptic(); setTab('bag');} }, e(BagIc,{s:16,c:"currentColor"}), "กระเป๋า")
      ),
      e('div', { className: 'tb-sep' }),
      e('div', { className: 'tb-src' },
        e(SearchIc, {s:18}),
        e('input', { placeholder:"ค้นหาร้านค้า, แบรนด์ หรือสถานที่...", value:q, onChange: ev => {setQ(ev.target.value); setMR(null);} }),
        q && e('button', { style:{cursor:'pointer',color:'#A0A0A0',padding:'0 8px',background:'none',border:'none',fontSize:18}, onClick:()=>{triggerHaptic(); setQ(''); setMR(null);} }, "✕"),
        e('button', { className:'tb-mic', onClick:()=>openVoice("search"), title:"ค้นหาด้วยเสียง" }, e(MicIc,{s:18}))
      ),
      e('div', { className: 'tb-vws' },
        e('button', { className: `t-vw ${view==='grid'?'on':''}`, onClick:()=>{triggerHaptic(); setView('grid');} }, e(GridIc,{s:20})),
        e('button', { className: `t-vw ${view==='list'?'on':''}`, onClick:()=>{triggerHaptic(); setView('list');} }, e(ListIc,{s:20}))
      )
    ),

    // FILTERS
    e('div', { className: 'f-row' },
      e('div', { className: 'f-wrap' },
        e('button', { className: `f-pill ${cond==='all'?'on':''}`, onClick:()=>{triggerHaptic(); setCond('all');} }, "ทั้งหมด"),
        e('button', { className: `f-pill ${cond==='new'?'on':''}`, onClick:()=>{triggerHaptic(); setCond('new');} }, e(TimeIc,{s:15}), "มือ 1"),
        e('button', { className: `f-pill ${cond==='pre'?'on':''}`, onClick:()=>{triggerHaptic(); setCond('pre');} }, e(UsersIc,{s:15}), "มือ 2"),
        e('button', { className: `f-pill ${selBr.length>0?'on':''}`, onClick:()=>{triggerHaptic(); setSheet(true);} },
          e(FolderIc,{s:15}), "เลือกแบรนด์",
          selBr.length > 0 && e('span', {style:{background:'#8F6D44',color:'white',padding:'2px 8px',borderRadius:12,fontSize:11,marginLeft:4}}, selBr.length))
      ),
      e('div', { className: 'f-right' },
        (cond!=="all" || selBr.length>0 || q) && e('button', {
          className: 'f-clear',
          onClick:()=>{triggerHaptic(); setSelBr([]);setCond("all");setQ("");setMR(null);showToast("ล้างตัวกรองแล้ว");}
        }, "ล้างทั้งหมด"),
        e('div', { className: 'f-total' }, `ทั้งหมด ${dispCount} ร้านค้า`)
      )
    ),

    // STORE LISTS
    tab === "all" ? e('div', null,
      e(RenderSection, { title:"ร้านนาฬิกา", count:ws.length, stores:ws, type:"watch", bf:mR?[mR.brand]:selBr, view, onOpen:(st,ty)=>setDet({store:st,type:ty}), onToast:showToast, isAllView:true }),
      e(RenderSection, { title:"ร้านกระเป๋า", count:bs.length, stores:bs, type:"bag", bf:mR?[mR.brand]:selBr, view, onOpen:(st,ty)=>setDet({store:st,type:ty}), onToast:showToast, isAllView:true }),
      dispCount === 0 && e('div', {style:{padding:'60px 20px',textAlign:'center'}},
        e('div', {style:{color:'#EFE4D8',fontSize:18,marginBottom:16,fontWeight:300}}, "ไม่พบร้านค้าที่ตรงกับเงื่อนไขการค้นหา"),
        suggestedBrand && e('div', {style:{background:'#FFF',borderRadius:20,padding:24,boxShadow:'0 16px 40px rgba(90,60,30,0.12)',display:'inline-block',maxWidth:400,width:'100%',border:'1px solid #EFE4D8'}},
          e('div', {style:{color:'#5A4A3D',fontSize:15,marginBottom:8}}, "คุณหมายถึงแบรนด์นี้หรือเปล่า?"),
          e('div', {style:{fontSize:24,fontWeight:700,color:'var(--pri)',marginBottom:20}}, suggestedBrand),
          e('button', {className:'c-cta', style:{width:'100%',justifyContent:'center',height:48,fontSize:15,borderRadius:24}, onClick:()=>{triggerHaptic(); setQ(suggestedBrand);}}, "ดูร้านค้าทั้งหมด", e(ChevRightIc,{s:18}))
        )
      )
    ) : e('div', null,
      e(RenderSection, { title: tab==="watch"?"ร้านนาฬิกา":"ร้านกระเป๋า", count:(tab==="watch"?ws:bs).length, stores:(tab==="watch"?ws:bs), type:tab, bf:mR?[mR.brand]:selBr, view, onOpen:(st,ty)=>setDet({store:st,type:ty}), onToast:showToast, isAllView:false })
    ),

    // ══ BRAND SHEET MODAL ══
    sheet && e('div', { className:'ov', onClick:()=>{triggerHaptic(); setSheet(false);} },
      e(BrandSheet, {
        selBr, setSelBr, sheetQ, setSheetQ,
        onClose:()=>{ triggerHaptic(); setSheet(false); },
        onVoice:()=>openVoice("sheet")
      })
    ),

    // ══ DETAIL MODAL ══
    detStore && e('div', { className:'ov', onClick:()=>{triggerHaptic(); setDet(null);} },
      e('div', { className:'sh', onClick:ev=>ev.stopPropagation() },

        // Sticky header
        e('div', { className:'d-sticky-hdr' },
          e('div', { className:'d-sh-left' },
            e('div', { className:'d-sh-av', style:{background:hue(detStore.n)} }, detStore.n.charAt(0)),
            e('div', { className:'d-sh-nm' },
              detStore.n, e(CertIc,{s:16}),
              detStore.w.length > 0 && e(WatchIc,{s:16,c:"#A07850"}),
              detStore.b.length > 0 && e(BagIc,{s:16,c:"#A07850"})
            )
          ),
          e('button', { className:'d-sh-close', onClick:()=>{triggerHaptic(); setDet(null);} }, "✕")
        ),

        // Scrollable body
        e('div', { className:'sh-body-detail' },
          e('div', {className:'d-loc'}, e(LocIc,{s:14}), activeBranch ? activeBranch.a : detStore.a),
          e('div', {className:'d-tags'},
            detStore.c && detStore.c.map(c => e('span', {key:c, className:`t-cond ${c}`}, c==="new"?"สินค้าใหม่มือ 1":"สินค้ามือสอง")),
            e('span', {className:`t-cond ${detStore.stock==='ready'?'rdy':detStore.stock==='preorder'?'po':'ask'}`},
              detStore.stock==='ready'?'พร้อมส่ง':detStore.stock==='preorder'?'Pre-Order':'ต้องสอบถามสต็อก')
          ),
          e('div', { className:'d-socs' },
            dSocKeys.map(k => e('a', {
              key:k, className:'d-soc',
              href: socUrl(k, activeSoc[k]),
              target: k !== 'tel' ? '_blank' : undefined,
              rel: k !== 'tel' ? 'noopener noreferrer' : undefined,
              onClick: () => { triggerHaptic(); if (k !== 'tel') showToast(`กำลังเปิด ${SOC[k].label}`); }
            },
              e('div', {className:'d-s-ic'}, e(Ico, {k, s:18, color:"currentColor"})),
              e('div', {className:'d-s-txt'},
                e('div', {className:'d-s-lbl'}, SOC[k].label),
                e('div', {className:'d-s-val'}, activeSoc[k])
              )
            ))
          ),
          detStore.w.length > 0 && e('div', {className:'d-sec'},
            e('div', {className:'d-st'}, e(WatchIc,{s:16,c:"currentColor"}), `แบรนด์นาฬิกา (${detStore.w.length})`),
            e('div', {className:'d-tag-wrap'}, detStore.w.map(b => e('span',{key:b,className:'m-tag'},b)))
          ),
          detStore.b.length > 0 && e('div', {className:'d-sec'},
            e('div', {className:'d-st'}, e(BagIc,{s:16,c:"currentColor"}), `แบรนด์กระเป๋า (${detStore.b.length})`),
            e('div', {className:'d-tag-wrap'}, detStore.b.map(b => e('span',{key:b,className:'m-tag'},b)))
          ),
          otherBranches.length > 0 && e('div', {className:'d-sec', style:{borderTop:'1px solid #EBEBEB',paddingTop:16}},
            e('div', {className:'d-st'}, e(FolderIc,{s:14,c:"currentColor"}), "เลือกดูข้อมูลสาขาอื่น"),
            e('div', {className:'d-br-srch'},
              e(SearchIc,{s:14}),
              e('input', {placeholder:"ค้นหาสาขา...", value:brQ, onChange:ev=>setBrQ(ev.target.value)})
            ),
            e('div', {className:'d-br-list'},
              otherBranches
                .filter(br => !brQ || br.n.toLowerCase().includes(brQ.toLowerCase()) || br.a.toLowerCase().includes(brQ.toLowerCase()))
                .map(br => e('div', {
                  key:br.id,
                  style:{
                    background:'#FAFAFA', border:'1px solid #EAEAEA', padding:'10px 12px', borderRadius:'12px',
                    display:'flex', justifyContent:'space-between', alignItems:'center', cursor:'pointer', transition:'all 0.3s ease',
                    ...(selBranchId===br.id ? {borderColor:'var(--pri)', background:'#FFFBF5', boxShadow:'0 4px 12px rgba(162,123,82,0.1)'} : {})
                  },
                  onClick:()=>{ triggerHaptic(); setSelBranchId(selBranchId===br.id ? null : br.id); showToast(selBranchId===br.id ? "ยกเลิกเลือกสาขา" : `เลือกสาขา: ${br.n}`); }
                },
                  e('div', {style:{flex:1,minWidth:0}},
                    e('div', {style:{fontSize:13,fontWeight:600,color:'#222',whiteSpace:'nowrap',overflow:'hidden',textOverflow:'ellipsis'}}, br.n),
                    e('div', {style:{fontSize:11,color:'#888',display:'flex',alignItems:'center',gap:4,marginTop:2}}, e(LocIc,{s:10}), br.a)
                  ),
                  selBranchId===br.id && e('span', {style:{fontSize:12,color:'var(--pri)',fontWeight:600,display:'flex',alignItems:'center',gap:4,flexShrink:0}}, e(CheckIc,{s:14,stroke:"currentColor"}))
                ))
            )
          ),
          e('div', { className:'d-acts' },
            e('button', {className:'d-a sec', onClick:(ev)=>openMap(activeBranch ? activeBranch.a : detStore.a, ev)}, e(LocIc,{s:16}), "แผนที่นำทาง"),
            e('button', {className:'d-a pri', onClick:(ev)=>applyLoan(detStore, ev)}, "สมัครสินเชื่อ", e(ChevRightIc,{s:16}))
          )
        )
      )
    ),

    // ══ VOICE SEARCH ══
    voiceOpen && e('div', { className:'voice-ov' },
      e('button', {className:'voice-close', onClick:closeVoice}, "✕"),
      e('div', {className:'voice-inner'},
        e('div', {className:'voice-status'},
          voiceError ? "เกิดข้อผิดพลาด" :
          voiceListening ? "กำลังฟังเสียงของคุณ..." :
          voiceText ? "กำลังประมวลผล..." : "แตะไมค์เพื่อพูด"
        ),
        e('div', {className:'voice-mic-wrap'},
          voiceListening && e('div', {className:'voice-pulse'}),
          voiceListening && e('div', {className:'voice-pulse'}),
          voiceListening && e('div', {className:'voice-pulse'}),
          e('button', {
            className:`voice-mic-btn ${voiceListening ? '' : 'idle'}`,
            onClick: voiceListening ? null : startListening, disabled: voiceListening
          }, e(MicIc, {s:44}))
        ),
        e('div', {className:`voice-text ${voiceText ? '' : 'placeholder'}`},
          voiceText || (voiceListening ? "กำลังฟังเสียงของคุณ..." : "กรุณาพูดชื่อแบรนด์ รุ่น หรือร้านค้า...")
        ),
        voiceListening && e('div', {className:'voice-waveform'},
          [1,2,3,4,5,6,7,8,9].map(i => e('div', {key:i, className:'voice-bar'}))
        ),
        !voiceListening && !voiceText && !voiceError && e('div', {className:'voice-hint'},
          'ตัวอย่างเช่น: "Rolex", "Hermès", "ทองปาเต๊ะ", หรือ "พารากอน"'
        ),
        voiceError && e('div', {className:'voice-err'}, voiceError),
        e('div', {className:'voice-actions'},
          e('button', {className:'voice-btn ghost', onClick:closeVoice}, "ยกเลิก"),
          voiceText && !voiceListening && e('button', {className:'voice-btn primary', onClick:submitVoice}, "ค้นหาเลย", e(ChevRightIc,{s:18})),
          !voiceText && !voiceListening && voiceError && e('button', {className:'voice-btn primary', onClick:startListening}, e(MicIc,{s:18}), "ลองพูดอีกครั้ง")
        )
      )
    ),

    toast && e('div', {className:'toast'},
      e('div', {className:'toast-ic'}, e(CheckIc,{s:14, stroke:"white"})),
      toast
    )
  );
}

const root = ReactDOM.createRoot(document.getElementById('root'));
root.render(e(App));
</script>
</body>
</html>
