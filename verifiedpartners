  const startListening = useCallback(() => {
    const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (!SR) {
      setVoiceError("เบราว์เซอร์นี้ไม่รองรับการค้นหาด้วยเสียง");
      return;
    }
    setVoiceError(null);
    setVoiceText("");
    try {
      const r = new SR();
      r.lang = "th-TH";
      r.continuous = false;
      r.interimResults = true;
      r.onstart = () => setVoiceListening(true);
      r.onresult = (ev) => {
        let text = "";
        for (let i = 0; i < ev.results.length; i++) text += ev.results[i][0].transcript;
        setVoiceText(text);
      };
      r.onerror = (ev) => {
        setVoiceListening(false);
        if (ev.error === 'not-allowed') setVoiceError("กรุณาอนุญาตให้ใช้งานไมโครโฟนบนเบราว์เซอร์");
        else if (ev.error === 'no-speech') setVoiceError("ไม่ได้ยินเสียง กรุณากดพูดอีกครั้ง");
        else if (ev.error === 'network') setVoiceError("การเชื่อมต่อเครือข่ายผิดพลาด");
        else setVoiceError("เกิดข้อผิดพลาด กรุณาลองใหม่");
      };
      r.onend = () => setVoiceListening(false);
      recogRef.current = r;
      r.start();
