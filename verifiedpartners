function Card({ store, type, bf, onOpen, onToast }) {
  const brands = type === "watch" ? store.w : type === "bag" ? store.b : [...store.w, ...store.b];
  if (bf.length > 0 && !bf.some(x => brands.includes(x))) return null;

  const show = brands.slice(0, 2);
  const extra = brands.length > 2 ? brands.length - 2 : 0;
  const branchCount = (store.branches || []).length + 1;
  const socKeys = ["tel","line","ig","fb","tiktok","x"].filter(k => store.soc[k]).slice(0, 4);

  return e('div', { className: 'card', onClick: () => onOpen(store, type) },
    e('div', { className: 'c-head' },
      e('div', { className: 'c-av', style:{background:hue(store.n)} }, store.n.charAt(0)),
      e('div', { className: 'c-info' },
