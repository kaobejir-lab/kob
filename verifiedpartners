                    key:brand, className:`sh-item ${sel?"on":""}`,
                    style:{padding:'8px 10px',borderRadius:12},
                    onClick:()=>setSelBr(p => p.includes(brand) ? p.filter(x=>x!==brand) : [...p, brand])
                  },
                    e('div', {className:'sh-ic', style:{width:24,height:24,fontSize:11,background:hue(brand)}}, brand.charAt(0)),
                    e('div', {style:{fontSize:13,fontWeight:500,flex:1}}, brand)
                  );
                })
            ),
            e('div', {className:'sh-sec-t'}, "นาฬิกา (Watches)"),
            e('div', {className:'sh-grid'},
              WB.filter(b => !["Rolex","Patek Philippe","Audemars Piguet"].includes(b))
                .filter(b => !sheetQ || b.toLowerCase().includes(sheetQ.toLowerCase()))
                .map(brand => {
                  const sel = selBr.includes(brand);
                  return e('div', {
                    key:brand, className:`sh-item ${sel?"on":""}`,
                    onClick:()=>setSelBr(p => p.includes(brand) ? p.filter(x=>x!==brand) : [...p, brand])
                  },
                    e('div', {className:'sh-ic', style:{background:hue(brand)}}, brand.charAt(0)),
                    e('div', {style:{fontSize:14,fontWeight:500}}, brand)
                  );
                })
            ),
            e('div', {className:'sh-sec-t'}, "กระเป๋า (Bags)"),
            e('div', {className:'sh-grid'},
              BB.filter(b => !["Hermès","Chanel","Louis Vuitton"].includes(b))
                .filter(b => !sheetQ || b.toLowerCase().includes(sheetQ.toLowerCase()))
                .map(brand => {
                  const sel = selBr.includes(brand);
                  return e('div', {
                    key:brand, className:`sh-item ${sel?"on":""}`,
                    onClick:()=>setSelBr(p => p.includes(brand) ? p.filter(x=>x!==brand) : [...p, brand])
                  },
                    e('div', {className:'sh-ic', style:{background:hue(brand)}}, brand.charAt(0)),
                    e('div', {style:{fontSize:14,fontWeight:500}}, brand)
                  );
                })
            )
          )
        ),
        e('button', {
          className:'c-cta',
          style:{width:"100%",height:54,justifyContent:"center",fontSize:16, borderRadius:27},
          onClick:()=>setSheet(false)
        }, `ดูร้านค้า${selBr.length > 0 ? ` (${selBr.length})` : ""}`, e(ChevRightIc,{s:18}))
      )
    ),

    // DETAIL MODAL
    detStore && e('div', { className:'ov', onClick:()=>setDet(null) },
      e('div', { className:'sh', onClick:ev=>ev.stopPropagation() },
        e('div', { className:'sh-bar' }),
        e('div', { className:'d-hdr' },
          e('div', {className:'d-av', style:{background:hue(detStore.n)}}, detStore.n.charAt(0)),
          e('div', {className:'d-info'},
            e('div', {className:'d-nm'},
              detStore.n,
              e(CertIc,{s:18}),
              detStore.w.length > 0 && e(WatchIc,{s:18,c:"#A07850"}),
              detStore.b.length > 0 && e(BagIc,{s:18,c:"#A07850"})
            ),
            e('div', {className:'d-loc'}, e(LocIc,{s:14}), activeBranch ? activeBranch.a : detStore.a),
            e('div', {className:'d-tags'},
              detStore.c && detStore.c.map(c => e('span', {key:c, className:`t-cond ${c}`}, c==="new"?"New":"Pre-owned")),
              e('span', {className:`t-cond ${detStore.stock==='ready'?'rdy':detStore.stock==='preorder'?'po':'ask'}`},
                detStore.stock==='ready'?'พร้อมส่ง':detStore.stock==='preorder'?'Pre-Order':'สอบถามสต็อก')
            )
          )
        ),

        e('div', { className:'d-socs' },
          dSocKeys.map(k => e('a', {
            key:k, className:'d-soc',
            href: socUrl(k, activeSoc[k]),
            target: k !== 'tel' ? '_blank' : undefined,
            rel: k !== 'tel' ? 'noopener noreferrer' : undefined,
            onClick: () => { if (k !== 'tel') showToast(`กำลังเปิด ${SOC[k].label}`); }
          },
            e('div', {className:'d-s-ic'}, e(Ico, {k, s:22, color:"currentColor"})),
            e('div', {className:'d-s-txt'},
              e('div', {className:'d-s-lbl'}, SOC[k].label),
              e('div', {className:'d-s-val'}, activeSoc[k])
            )
          ))
        ),

        detStore.w.length > 0 && e('div', {className:'d-sec'},
          e('div', {className:'d-st'}, e(WatchIc,{s:18,c:"currentColor"}), `แบรนด์นาฬิกาที่ขอสินเชื่อได้ (${detStore.w.length})`),
          e('div', {className:'d-tag-wrap'}, detStore.w.map(b => e('span',{key:b,className:'m-tag'},b)))
        ),
        detStore.b.length > 0 && e('div', {className:'d-sec'},
          e('div', {className:'d-st'}, e(BagIc,{s:18,c:"currentColor"}), `แบรนด์กระเป๋าที่ขอสินเชื่อได้ (${detStore.b.length})`),
          e('div', {className:'d-tag-wrap'}, detStore.b.map(b => e('span',{key:b,className:'m-tag'},b)))
        ),

        otherBranches.length > 0 && e('div', {className:'d-sec', style:{borderTop:'1px solid #EBEBEB',paddingTop:20}},
          e('div', {className:'d-st'}, e(FolderIc,{s:16,c:"currentColor"}), "สาขาอื่น ๆ ให้บริการ"),
          e('div', {className:'d-br-srch', style:{background:'#F9F7F3', padding:'12px 16px', borderRadius:16, display:'flex', alignItems:'center', gap:10, marginBottom:12, border:'1px solid #EBE4DA'}},
            e(SearchIc,{s:16}),
            e('input', {placeholder:"ค้นหาสาขาหรือที่ตั้ง...", value:brQ, onChange:ev=>setBrQ(ev.target.value), style:{flex:1, border:'none', background:'transparent', outline:'none', fontSize:14}})
          ),
          e('div', {className:'d-br-list', style:{display:'flex', flexDirection:'column', gap:8, maxHeight:220, overflowY:'auto'}},
            otherBranches
              .filter(br => !brQ || br.n.toLowerCase().includes(brQ.toLowerCase()) || br.a.toLowerCase().includes(brQ.toLowerCase()))
              .map(br => e('div', {
                key:br.id,
                className:'d-brn',
                style: {
                  background:'#FAFAFA', border:'1px solid #EAEAEA', padding:'14px 16px', borderRadius:'14px', 
                  display:'flex', justifyContent:'space-between', alignItems:'center', cursor:'pointer', transition:'all 0.3s ease',
                  ...(selBranchId===br.id ? {borderColor:'var(--pri)', background:'#FFFBF5', boxShadow:'0 4px 12px rgba(162,123,82,0.1)'} : {})
                },
                onClick:()=>{ setSelBranchId(selBranchId===br.id ? null : br.id); showToast(selBranchId===br.id ? "ยกเลิกเลือกสาขา" : `เลือกสาขา: ${br.n}`); }
              },
                e('div', {style:{flex:1}},
                  e('div', {className:'d-brn-name', style:{fontSize:14, fontWeight:600, color:'#222'}}, br.n),
                  e('div', {className:'d-brn-loc', style:{fontSize:12, color:'#888', display:'flex', alignItems:'center', gap:4, marginTop:4}}, e(LocIc,{s:12}), br.a)
                ),
                selBranchId===br.id && e('span', {style:{fontSize:12,color:'var(--pri)',fontWeight:600,display:'flex',alignItems:'center',gap:4}}, e(CheckIc,{s:14, stroke:"currentColor"}), "เลือกอยู่")
              ))
          )
        ),

        e('div', { className:'d-acts' },
          e('button', {
            className:'d-a sec',
            onClick:(ev)=>openMap(activeBranch ? activeBranch.a : detStore.a, ev)
          }, e(LocIc,{s:18}), "ดูแผนที่"),
          e('button', {
            className:'d-a pri',
            onClick:(ev)=>applyLoan(detStore, ev)
          }, "สมัครสินเชื่อ", e(ChevRightIc,{s:18}))
        )
      )
    ),

    // ═══ VOICE SEARCH ═══
    voiceOpen && e('div', { className:'voice-ov' },
      e('button', {className:'voice-close', onClick:closeVoice, title:"ปิด"}, "✕"),
      e('div', {className:'voice-inner'},
        e('div', {className:'voice-status'},
          voiceError ? "เกิดข้อผิดพลาด" :
          voiceListening ? "กำลังฟังเสียงของคุณ..." :
          voiceText ? "พร้อมค้นหา" : "แตะไมค์เพื่อพูด"
        ),
        e('div', {className:'voice-mic-wrap'},
          voiceListening && e('div', {className:'voice-pulse'}),
          voiceListening && e('div', {className:'voice-pulse'}),
          voiceListening && e('div', {className:'voice-pulse'}),
          e('button', {
            className:`voice-mic-btn ${voiceListening ? '' : 'idle'}`,
            onClick: voiceListening ? null : startListening,
            disabled: voiceListening
          }, e(MicIc, {s:44}))
        ),
        e('div', {className:`voice-text ${voiceText ? '' : 'placeholder'}`},
          voiceText || (voiceListening ? "กำลังฟังเสียงของคุณ..." : "กรุณาพูดชื่อแบรนด์ รุ่น หรือร้านค้า...")
        ),
        voiceListening && e('div', {className:'voice-waveform'},
          [1,2,3,4,5,6,7,8,9].map(i => e('div', {key:i, className:'voice-bar'}))
        ),
        !voiceListening && !voiceText && !voiceError && e('div', {className:'voice-hint'},
          'ตัวอย่างเช่น: "Rolex", "Hermès Birkin", หรือ "สยามพารากอน"'
        ),
        voiceError && e('div', {className:'voice-err'}, voiceError),
        e('div', {className:'voice-actions'},
          e('button', {className:'voice-btn ghost', onClick:closeVoice}, "ยกเลิก"),
          voiceText && !voiceListening && e('button', {className:'voice-btn primary', onClick:submitVoice},
            "ค้นหาเลย", e(ChevRightIc,{s:18})
          ),
          !voiceText && !voiceListening && voiceError && e('button', {className:'voice-btn primary', onClick:startListening},
            e(MicIc,{s:18}), "ลองพูดอีกครั้ง"
          )
        )
      )
    ),

    toast && e('div', {className:'toast'},
      e('div', {className:'toast-ic'}, e(CheckIc,{s:14, stroke:"white"})),
      toast
    )
  );
}

const root = ReactDOM.createRoot(document.getElementById('root'));
root.render(e(App));
</script>
</body>
</html>
