}
@keyframes toastIn {
  from { transform: translate(-50%, 40px); opacity: 0; }
  to { transform: translate(-50%, 0); opacity: 1; }
}
.toast-ic { width: 24px; height: 24px; border-radius: 50%; background: #4CAF50; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
