function RenderSection({ title, count, stores, type, bf, view, onOpen, onToast, isAllView }) {
  const [lim, setLim] = useState(6);
  if (stores.length === 0) return null;
  const show = isAllView ? stores.slice(0, lim) : stores;
  return e('div', { style: { marginBottom: 24 } },
    e('div', { className: 's-head' }, e('h2', { className: 'sh-t' }, title, e('span', { className: 'sh-sub' }, `${count} ร้าน`))),
    e('div', { className: view === 'grid' ? 'grid' : 'list-layout' },
      show.map(s => e(Card, { key: s.id, store: s, type, bf, onOpen, onToast }))
    ),
    (isAllView && stores.length > lim) && e('button', { className: 'btn-more', onClick: () => setLim(p => p + 6) },
      `ดู${title}เพิ่มเติม (${stores.length - lim} ร้าน)`, e(ChevRightIc, {s:16})
    )
  );
}

